# Server Configuration
PORT=3000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# Choose ONE database type by uncommenting
# ============================================

# --- 'mongodb', 'postgres', mysql or inmemory ---
DB_TYPE=inmemory
MONGODB_URI=mongodb://localhost:27017/travel_explorer
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/travel_explorer

# --- PostgreSQL ---
# DB_TYPE=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=travel_explorer
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# --- MySQL ---
# DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DB=travel_explorer
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_super_secret_key_change_in_production
